{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": ["**/*.spec.ts"],
  "entry": ["demos/src/**/index.*"],
  "ignoreExports": [
    {
      "file": "**/*",
      "exports": ["default"]
    }
  ],
  "usedClassMembers": [
    {
      "implements": "DecorationSource",
      "members": ["map", "forChild", "eq", "locals", "forEachSet"]
    }
  ],
  "health": {
    "ignore": ["demos/**", "*.config.ts"]
  }
}
