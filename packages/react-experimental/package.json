{
  "name": "@tiptap/react-experimental",
  "version": "3.27.3",
  "private": true,
  "description": "Experimental React-owned rendering engine for Tiptap",
  "keywords": [
    "tiptap",
    "tiptap react renderer"
  ],
  "homepage": "https://tiptap.dev",
  "bugs": {
    "url": "https://github.com/ueberdosis/tiptap/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ueberdosis/tiptap",
    "directory": "packages/react-experimental"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/ueberdosis"
  },
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./menus": {
      "types": {
        "import": "./dist/menus/index.d.ts",
        "require": "./dist/menus/index.d.cts"
      },
      "import": "./dist/menus/index.js",
      "require": "./dist/menus/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@types/use-sync-external-store": "^0.0.6",
    "fast-equals": "^5.3.3",
    "use-sync-external-store": "^1.4.0"
  },
  "devDependencies": {
    "@tiptap/core": "workspace:^",
    "@tiptap/pm": "workspace:^",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prosemirror-view": "1.41.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.23"
  },
  "peerDependencies": {
    "@tiptap/core": "workspace:*",
    "@tiptap/pm": "workspace:*",
    "@types/react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "@types/react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "optionalDependencies": {
    "@tiptap/extension-bubble-menu": "workspace:^",
    "@tiptap/extension-floating-menu": "workspace:^"
  }
}
