{
  "name": "@tiptap/solid",
  "version": "3.27.1",
  "description": "Solid components for tiptap",
  "keywords": [
    "tiptap",
    "tiptap solid components"
  ],
  "homepage": "https://tiptap.dev",
  "bugs": {
    "url": "https://github.com/ueberdosis/tiptap/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ueberdosis/tiptap",
    "directory": "packages/solid"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/ueberdosis"
  },
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "solid": "./dist/index.js",
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./menus": {
      "solid": "./dist/menus/index.js",
      "types": {
        "import": "./dist/menus/index.d.ts",
        "require": "./dist/menus/index.d.cts"
      },
      "import": "./dist/menus/index.js",
      "require": "./dist/menus/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup"
  },
  "devDependencies": {
    "@tiptap/core": "workspace:^",
    "@tiptap/pm": "workspace:^",
    "esbuild-plugin-solid": "^0.6.0",
    "solid-js": "^1.9.5"
  },
  "peerDependencies": {
    "@floating-ui/dom": "^1.0.0",
    "@tiptap/core": "workspace:*",
    "@tiptap/pm": "workspace:*",
    "solid-js": "^1.8.0"
  },
  "optionalDependencies": {
    "@tiptap/extension-bubble-menu": "workspace:^",
    "@tiptap/extension-floating-menu": "workspace:^"
  }
}
